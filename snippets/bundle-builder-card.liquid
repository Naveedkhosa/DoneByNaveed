{%- comment -%}
  Renders one selectable bundle-builder product card.
  @param {product} product
  @param {string} product_series - space-separated collection handles for tab filtering
  @param {number} global_index - used for eager-loading first row images
{%- endcomment -%}
{%- unless product.tags contains 'engraving-fee' -%}
{%- if product.available -%}
  {%- assign variant = product.selected_or_first_available_variant -%}
  <div
    class="bundle-card"
    ref="cards[]"
    role="button"
    tabindex="0"
    aria-pressed="false"
    aria-label="{{ product.title | escape }} — select for bundle"
    data-product-id="{{ product.id }}"
    data-variant-id="{{ variant.id }}"
    data-price="{{ variant.price }}"
    data-compare-price="{{ variant.compare_at_price | default: variant.price }}"
    data-available="{{ product.available }}"
    data-title="{{ product.title | escape }}"
    data-image="{{ product.featured_image | image_url: width: 100 }}"
    data-series="{{ product_series }}"
    on:click="/handleCardClick"
    on:keydown="/handleCardKeydown"
  >
    <div class="bundle-card__checkbox">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>

    <div class="bundle-card__image">
      {%- if product.featured_image != blank -%}
        {%- liquid
          assign img_loading = 'lazy'
          assign img_priority = 'auto'
          if global_index <= 8
            assign img_loading = 'eager'
            assign img_priority = 'high'
          endif
        -%}
        <img
          srcset="{{ product.featured_image | image_url: width: 300 }} 300w, {{ product.featured_image | image_url: width: 500 }} 500w, {{ product.featured_image | image_url: width: 700 }} 700w"
          sizes="(max-width: 500px) 50vw, (max-width: 750px) 50vw, (max-width: 1300px) 33vw, 25vw"
          src="{{ product.featured_image | image_url: width: 500 }}"
          width="500"
          height="500"
          alt="{{ product.title | escape }}"
          loading="{{ img_loading }}"
          fetchpriority="{{ img_priority }}"
          decoding="async"
        >
      {%- endif -%}

      {%- if product.compare_at_price and product.compare_at_price > product.price -%}
        {%- assign discount = product.compare_at_price | minus: product.price -%}
        {%- assign percent = discount | times: 100 | divided_by: product.compare_at_price -%}
        <span class="bundle-card__badge">{{ percent }}% OFF</span>
      {%- endif -%}
    </div>

    <div class="bundle-card__info">
      <h3 class="bundle-card__title">{{ product.title }}</h3>
      <div class="bundle-card__price">
        <span class="bundle-card__current-price">{{ variant.price | money }}</span>
        {%- if variant.compare_at_price and variant.compare_at_price > variant.price -%}
          <span class="bundle-card__compare-price">{{ variant.compare_at_price | money }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}
{%- endunless -%}
